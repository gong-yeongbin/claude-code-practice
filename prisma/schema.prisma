// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  BUYER
  SOURCING
  MANUFACTURER

  @@map("user_role")
}

/// 시스템 사용자. 역할에 따라 주문자/소싱팀/생산자로 구분
model User {
  id             BigInt          @id @default(autoincrement())
  name           String          @db.VarChar(100)
  /// BUYER(주문자), SOURCING(소싱팀), MANUFACTURER(생산자) — 권한 검증의 기준
  role           UserRole
  createdAt      DateTime        @default(now()) @db.Timestamptz @map("created_at")
  updatedAt      DateTime        @updatedAt @db.Timestamptz @map("updated_at")
  purchaseOrders PurchaseOrder[]
  requestedChanges ChangeRequest[] @relation("ChangeRequester")
  reviewedChanges  ChangeRequest[] @relation("ChangeReviewer")

  @@map("users")
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  IN_PRODUCTION
  COMPLETED

  @@map("order_status")
}

/// 발주서의 메타정보와 워크플로우 상태. 변경되는 내용(수량/납기 등)은 버전 테이블에 저장
model PurchaseOrder {
  id             BigInt      @id @default(autoincrement())
  orderNo        String      @unique @db.VarChar(50) @map("order_no")
  /// 발주서를 생성한 주문자(users.id)
  buyerId        BigInt      @map("buyer_id")
  /// DRAFT→PENDING→CONFIRMED→IN_PRODUCTION→COMPLETED. CONFIRMED 이상부터 변경요청 가능
  status         OrderStatus @default(DRAFT)
  /// 현재 유효한 버전 번호. 최신 스냅샷을 가리킴
  currentVersion Int         @default(1) @map("current_version")
  createdAt      DateTime    @default(now()) @db.Timestamptz @map("created_at")
  updatedAt      DateTime    @updatedAt @db.Timestamptz @map("updated_at")
  buyer          User        @relation(fields: [buyerId], references: [id])
  changeRequests ChangeRequest[]
  versions       PurchaseOrderVersion[]

  @@map("purchase_order")
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("change_request_status")
}

/// 주문자가 확정된 발주서에 올린 변경 요청. 소싱팀이 승인/반려
model ChangeRequest {
  id              BigInt              @id @default(autoincrement())
  purchaseOrderId BigInt              @map("purchase_order_id")
  /// 변경을 요청한 주문자(users.id)
  requesterId     BigInt              @map("requester_id")
  /// 변경 사유 (주문자 작성)
  reason          String              @db.Text
  /// 필드별 변경 내역. 예: {"quantity":{"old":1000,"new":1500},"delivery_date":{"old":"2025-03-15","new":"2025-03-25"}}
  changes         Json                @db.JsonB
  /// PENDING(대기) / APPROVED(승인·발주서 반영) / REJECTED(반려)
  status          ChangeRequestStatus @default(PENDING)
  /// 검토한 소싱팀 담당자(users.id). 처리 전에는 NULL
  reviewerId      BigInt?             @map("reviewer_id")
  /// 승인/반려 시 검토 의견
  reviewComment   String?             @db.Text @map("review_comment")
  reviewedAt      DateTime?           @db.Timestamptz @map("reviewed_at")
  createdAt       DateTime            @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime            @updatedAt @db.Timestamptz @map("updated_at")
  purchaseOrder   PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id])
  requester       User                @relation("ChangeRequester", fields: [requesterId], references: [id])
  reviewer        User?               @relation("ChangeReviewer", fields: [reviewerId], references: [id])
  versions        PurchaseOrderVersion[]

  @@map("change_request")
}

/// 발주서 내용의 버전별 전체 스냅샷. 버전/시점/비교 조회의 기반
model PurchaseOrderVersion {
  id              BigInt         @id @default(autoincrement())
  purchaseOrderId BigInt         @map("purchase_order_id")
  /// 버전 번호 (1, 2, 3...). 생성 시 1, 변경요청 승인마다 +1
  versionNo       Int            @map("version_no")
  productName     String         @db.VarChar(255) @map("product_name")
  quantity        Int
  unitPrice       Decimal        @db.Decimal(12, 2) @map("unit_price")
  deliveryDate    DateTime       @db.Date @map("delivery_date")
  /// 색상·사이즈 등 사양 (유동 필드라 JSONB)
  spec            Json?          @db.JsonB
  /// 이 버전을 만든 변경요청. 최초 버전(v1)은 NULL
  changeRequestId BigInt?        @map("change_request_id")
  /// 이 버전이 유효해진 시각 (inclusive)
  validFrom       DateTime       @db.Timestamptz @map("valid_from")
  /// 다음 버전 생성 시 채워짐 (exclusive). 현재 버전은 NULL
  validTo         DateTime?      @db.Timestamptz @map("valid_to")
  createdAt       DateTime       @default(now()) @db.Timestamptz @map("created_at")
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  changeRequest   ChangeRequest? @relation(fields: [changeRequestId], references: [id])

  @@unique([purchaseOrderId, versionNo], map: "uq_po_version")
  @@map("purchase_order_version")
}
